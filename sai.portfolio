          <p class="contact-sub stagger">Open to freelance projects, design collaborations, and brand work.</p>
        </div>
        <div class="stagger">
          <div class="c-item"><span class="c-lbl">Email</span><a href="mailto:nithsai925@gmail.com" class="c-val">nithsai925@gmail.com</a></div>
          <div class="c-item"><span class="c-lbl">Instagram</span><a href="https://instagram.com/sainith.r" target="_blank" class="c-val">@sainith.r</a></div>
          <div class="c-item"><span class="c-lbl">LinkedIn</span><a href="https://linkedin.com/in/nithsai966" target="_blank" class="c-val">linkedin.com/in/nithsai966</a></div>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Sainith Ramesh — UI/UX Designer</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg:    #0C0C0C;
      --bg2:   #141414;
      --bg3:   #1C1C1C;
      --white: #FFFFFF;
      --off:   #E8E4DC;
      --mid:   #888580;
      --line:  #222222;
      --faint: #2A2A2A;
    }

    *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
    html, body { width:100%; height:100%; overflow:hidden; }

    body {
      background: var(--bg);
      color: var(--off);
      font-family: 'Inter', sans-serif;
      font-weight: 300;
    }

    /* ── GRAIN ──────────────────────────────── */
    body::before {
      content:''; position:fixed; inset:0; pointer-events:none; z-index:9999; opacity:.2;
      background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='f'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23f)' opacity='.04'/%3E%3C/svg%3E");
    }

    /* ── PAGE SYSTEM ────────────────────────── */
    .page {
      position: fixed; inset:0;
      display: flex; flex-direction:column;
      overflow-y: auto;
      opacity: 0;
      pointer-events: none;
      transition: opacity .6s cubic-bezier(.16,1,.3,1),
                  transform .6s cubic-bezier(.16,1,.3,1);
    }

    .page.active {
      opacity: 1;
      pointer-events: all;
    }

    /* slide directions */
    .page.from-right { transform: translateX(60px); }
    .page.from-left  { transform: translateX(-60px); }
    .page.from-bottom{ transform: translateY(40px); }
    .page.active     { transform: translate(0,0); }
    .page.exit-left  { transform: translateX(-60px); opacity:0; }
    .page.exit-right { transform: translateX(60px); opacity:0; }

    /* ── NAV ────────────────────────────────── */
    .top-nav {
      position: fixed; top:0; left:0; right:0; z-index:500;
      padding: 24px 56px;
      display: flex; justify-content:space-between; align-items:center;
      background: rgba(12,12,12,.9);
      backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--line);
    }
    .nav-logo {
      font-family: 'Playfair Display', serif;
      font-size: 17px; color: var(--white); text-decoration:none;
      cursor: pointer;
    }
    .nav-right {
      display: flex; align-items:center; gap:32px;
    }
    .nav-section-indicator {
      font-size: 10px; letter-spacing:.2em; text-transform:uppercase;
      color: var(--mid);
      transition: color .3s;
    }
    .nav-menu-btn {
      background: none; border: 1px solid var(--line);
      color: var(--mid); cursor:pointer;
      font-size:10px; letter-spacing:.18em; text-transform:uppercase;
      padding: 8px 16px; font-family:'Inter',sans-serif;
      transition: border-color .25s, color .25s;
    }
    .nav-menu-btn:hover { border-color:var(--mid); color:var(--off); }

    /* ── MENU OVERLAY ───────────────────────── */
    #menu-overlay {
      position: fixed; inset:0; z-index:400;
      background: rgba(12,12,12,.97);
      display: flex; align-items:center; justify-content:center;
      opacity:0; pointer-events:none;
      transition: opacity .4s;
    }
    #menu-overlay.open { opacity:1; pointer-events:all; }

    .menu-list {
      list-style:none; display:flex; flex-direction:column; gap:8px;
      text-align: center;
    }
    .menu-list li {
      overflow:hidden;
    }
    .menu-list a {
      font-family: 'Playfair Display', serif;
      font-size: clamp(36px, 6vw, 72px);
      color: var(--off); text-decoration:none;
      letter-spacing:-.01em; line-height:1.1;
      display:block;
      transition: color .25s;
      cursor: pointer;
    }
    .menu-list a:hover { color: var(--white); }
    .menu-list .menu-num {
      font-family:'Inter',sans-serif;
      font-size:10px; letter-spacing:.2em; text-transform:uppercase;
      color:var(--mid); margin-right:12px;
    }
    .menu-close {
      position:absolute; top:28px; right:56px;
      background:none; border:none; color:var(--mid);
      font-size:10px; letter-spacing:.2em; text-transform:uppercase;
      cursor:pointer; font-family:'Inter',sans-serif;
      transition:color .25s;
    }
    .menu-close:hover { color:var(--white); }

    /* ── PAGE CONTENT PADDING ───────────────── */
    .page-inner {
      padding: 120px 56px 80px;
      flex:1;
    }

    /* ── BOTTOM NAV ─────────────────────────── */
    .bottom-nav {
      padding: 24px 56px;
      display: flex; justify-content:space-between; align-items:center;
      border-top: 1px solid var(--line);
      flex-shrink:0;
    }
    .btn-nav {
      background:none; border:none; cursor:pointer;
      font-family:'Inter',sans-serif;
      font-size:10px; letter-spacing:.2em; text-transform:uppercase;
      color:var(--mid); display:flex; align-items:center; gap:10px;
      transition:color .25s;
    }
    .btn-nav:hover { color:var(--white); }
    .btn-nav .arrow { font-size:14px; }
    .page-counter {
      font-size:10px; letter-spacing:.2em; color:var(--mid);
    }

    /* ── HERO PAGE ──────────────────────────── */
    #page-home .page-inner {
      display: flex; flex-direction:column; justify-content:center;
      min-height: calc(100vh - 73px - 69px);
      position:relative; overflow:hidden;
    }

    .hero-bg-letter {
      position:absolute; right:-40px; top:50%;
      transform:translateY(-50%);
      font-family:'Playfair Display',serif;
      font-size:50vw; line-height:1; color:transparent;
      -webkit-text-stroke:1px rgba(255,255,255,.025);
      pointer-events:none; user-select:none;
      animation: slowDrift 20s ease-in-out infinite;
    }
    @keyframes slowDrift {
      0%,100%{transform:translateY(-50%) translateX(0)}
      50%{transform:translateY(-52%) translateX(-10px)}
    }

    .hero-tag {
      font-size:10px; letter-spacing:.28em; text-transform:uppercase;
      color:var(--mid); margin-bottom:24px;
      display:flex; align-items:center; gap:14px;
    }
    .hero-tag::before { content:''; width:28px; height:1px; background:var(--mid); }

    .hero-name {
      font-family:'Playfair Display',serif;
      font-size:clamp(60px,10vw,140px);
      line-height:.88; letter-spacing:-.02em; color:var(--white);
      position:relative; z-index:1;
    }
    .hero-name .it { font-style:italic; color:var(--mid); }

    .hero-divider {
      width:100%; height:1px; background:var(--line); margin:40px 0;
    }

    .hero-bottom {
      display:flex; justify-content:space-between; align-items:flex-end;
      position:relative; z-index:1;
    }
    .hero-roles { display:flex; gap:12px; flex-wrap:wrap; }
    .hero-role {
      font-size:10px; letter-spacing:.14em; text-transform:uppercase;
      color:var(--mid); padding:7px 14px; border:1px solid var(--line);
      transition:border-color .25s, color .25s;
    }
    .hero-role:hover { border-color:var(--mid); color:var(--off); }
    .hero-cta {
      font-size:11px; letter-spacing:.2em; text-transform:uppercase;
      color:var(--white); display:flex; align-items:center; gap:10px;
      cursor:pointer; background:none; border:none;
      font-family:'Inter',sans-serif;
      transition:gap .3s;
    }
    .hero-cta:hover { gap:18px; }
    .hero-cta .arr { font-size:18px; }

    /* ── ABOUT PAGE ─────────────────────────── */
    #page-about .about-grid {
      display:grid; grid-template-columns:1.1fr 1fr; gap:80px; align-items:start;
    }
    .about-p {
      font-size:17px; line-height:1.85; color:var(--mid); margin-bottom:20px;
    }
    .about-p strong { color:var(--off); font-weight:500; }
    .info-table { display:flex; flex-direction:column; }
    .info-row {
      display:flex; gap:0; padding:13px 0; border-bottom:1px solid var(--line);
    }
    .info-row:first-child { border-top:1px solid var(--line); }
    .info-k { font-size:9px; letter-spacing:.18em; text-transform:uppercase; color:var(--mid); min-width:110px; }
    .info-v { font-size:13px; color:var(--off); }

    /* ── RESUME PAGE ────────────────────────── */
    #page-resume .res-grid {
      display:grid; grid-template-columns:1fr 1fr; gap:2px;
    }
    .res-col { background:var(--bg2); padding:40px; }
    .res-col-title {
      font-size:9px; letter-spacing:.22em; text-transform:uppercase;
      color:var(--mid); padding-bottom:16px; border-bottom:1px solid var(--line); margin-bottom:28px;
    }
    .res-item { padding:20px 0; border-bottom:1px solid var(--line); }
    .res-item:last-child { border-bottom:none; }
    .r-period { font-size:9px; letter-spacing:.14em; text-transform:uppercase; color:var(--mid); margin-bottom:7px; }
    .r-title { font-family:'Playfair Display',serif; font-size:20px; color:var(--white); margin-bottom:4px; }
    .r-sub { font-size:10px; letter-spacing:.1em; text-transform:uppercase; color:var(--mid); margin-bottom:7px; }
    .r-desc { font-size:13px; color:var(--mid); line-height:1.7; }

    /* ── SKILLS PAGE ────────────────────────── */
    #page-skills .skills-grid {
      display:grid; grid-template-columns:repeat(3,1fr); gap:2px;
    }
    .skill-box {
      background:var(--bg2); padding:36px 32px;
      border:1px solid var(--line); position:relative; overflow:hidden;
      transition:background .25s;
    }
    .skill-box::after {
      content:''; position:absolute; bottom:0; left:0;
      width:0; height:2px; background:var(--white);
      transition:width .4s cubic-bezier(.16,1,.3,1);
    }
    .skill-box:hover { background:var(--bg3); }
    .skill-box:hover::after { width:100%; }
    .skill-cat { font-size:9px; letter-spacing:.22em; text-transform:uppercase; color:var(--mid); margin-bottom:14px; }
    .skill-name { font-family:'Playfair Display',serif; font-size:22px; color:var(--white); margin-bottom:10px; }
    .skill-tools { font-size:11px; letter-spacing:.08em; color:var(--mid); line-height:1.6; }

    /* ── PROJECT PAGE ───────────────────────── */
    #page-project .proj-grid {
      display:grid; grid-template-columns:1fr 1fr; gap:2px;
    }
    .proj-main { background:var(--white); padding:52px 44px; color:var(--bg); }
    .proj-tag { font-size:9px; letter-spacing:.22em; text-transform:uppercase; color:#999; margin-bottom:20px; }
    .proj-title { font-family:'Playfair Display',serif; font-size:clamp(32px,5vw,60px); line-height:.92; margin-bottom:24px; color:var(--bg); }
    .proj-title em { font-style:italic; color:#555; }
    .proj-body-text { font-size:15px; color:#555; line-height:1.8; margin-bottom:28px; }
    .proj-stat { display:flex; gap:0; padding:11px 0; border-bottom:1px solid #E8E8E8; }
    .proj-stat:first-of-type { border-top:1px solid #E8E8E8; }
    .psl { font-size:9px; letter-spacing:.14em; text-transform:uppercase; color:#999; min-width:90px; }
    .psv { font-size:13px; color:#111; }

    .proj-side { background:var(--bg2); padding:52px 44px; }
    .proj-side-label { font-size:9px; letter-spacing:.22em; text-transform:uppercase; color:var(--mid); margin-bottom:24px; }
    .proj-side-p { font-size:15px; color:var(--mid); line-height:1.8; margin-bottom:14px; }
    .scope-list { margin-top:28px; }
    .scope-item {
      display:flex; align-items:center; gap:14px;
      padding:11px 0; border-bottom:1px solid var(--line);
      font-size:11px; letter-spacing:.1em; text-transform:uppercase; color:var(--mid);
      transition:color .2s;
    }
    .scope-item:hover { color:var(--off); }
    .scope-item::before { content:'—'; color:var(--white); flex-shrink:0; }

    /* ── INTERESTS PAGE ─────────────────────── */
    #page-interests .int-grid {
      display:grid; grid-template-columns:repeat(4,1fr); gap:2px;
    }
    .int-box {
      background:var(--bg2); padding:40px 28px;
      border:1px solid var(--line); transition:background .25s;
    }
    .int-box:hover { background:var(--bg3); }
    .int-n { font-size:9px; letter-spacing:.2em; color:var(--mid); margin-bottom:16px; }
    .int-name { font-family:'Playfair Display',serif; font-size:20px; color:var(--white); margin-bottom:10px; }
    .int-desc { font-size:11px; letter-spacing:.06em; color:var(--mid); line-height:1.65; }

    /* ── CONTACT PAGE ───────────────────────── */
    #page-contact .contact-grid {
      display:grid; grid-template-columns:1fr 1fr; gap:80px; align-items:start;
    }
    .contact-big {
      font-family:'Playfair Display',serif;
      font-size:clamp(44px,7vw,88px); line-height:.9; color:var(--white); margin-bottom:20px;
    }
    .contact-big em { font-style:italic; color:var(--mid); }
    .contact-sub { font-size:15px; color:var(--mid); line-height:1.7; }
    .c-item { display:flex; gap:20px; align-items:center; padding:18px 0; border-bottom:1px solid var(--line); }
    .c-item:first-child { border-top:1px solid var(--line); }
    .c-lbl { font-size:9px; letter-spacing:.18em; text-transform:uppercase; color:var(--mid); min-width:90px; }
    .c-val { font-size:14px; color:var(--off); text-decoration:none; transition:color .2s; }
    .c-val:hover { color:var(--white); }

    /* ── SECTION HEADER ─────────────────────── */
    .sec-head {
      display:flex; align-items:center; gap:20px; margin-bottom:48px;
    }
    .sec-num { font-size:10px; letter-spacing:.2em; text-transform:uppercase; color:var(--mid); }
    .sec-title {
      font-family:'Playfair Display',serif;
      font-size:clamp(28px,4vw,52px); color:var(--white); line-height:1;
    }
    .sec-title em { font-style:italic; color:var(--mid); }
    .sec-line { flex:1; height:1px; background:var(--line); }

    /* ── STAGGER REVEAL ─────────────────────── */
    .stagger { opacity:0; transform:translateY(20px); }
    .stagger.show {
      animation: staggerIn .6s cubic-bezier(.16,1,.3,1) forwards;
    }
    @keyframes staggerIn {
      to { opacity:1; transform:translateY(0); }
    }

    /* ── RESPONSIVE ─────────────────────────── */
    @media(max-width:900px){
      .top-nav, .page-inner, .bottom-nav { padding-left:24px; padding-right:24px; }
      .menu-close { right:24px; }
      #page-about .about-grid,
      #page-resume .res-grid,
      #page-project .proj-grid,
      #page-contact .contact-grid { grid-template-columns:1fr; }
      #page-skills .skills-grid,
      #page-interests .int-grid { grid-template-columns:1fr 1fr; }
      .hero-bottom { flex-direction:column; gap:20px; align-items:flex-start; }
    }
  </style>
</head>
<body>

  <!-- TOP NAV -->
  <nav class="top-nav">
    <span class="nav-logo" onclick="goTo('home')">Sainith Ramesh</span>
    <div class="nav-right">
      <span class="nav-section-indicator" id="nav-indicator">Home</span>
      <button class="nav-menu-btn" onclick="toggleMenu()">Menu</button>
    </div>
  </nav>

  <!-- MENU OVERLAY -->
  <div id="menu-overlay">
    <button class="menu-close" onclick="toggleMenu()">Close ✕</button>
    <ul class="menu-list">
      <li><a onclick="goTo('home');toggleMenu()"><span class="menu-num">00</span>Home</a></li>
      <li><a onclick="goTo('about');toggleMenu()"><span class="menu-num">01</span>About</a></li>
      <li><a onclick="goTo('resume');toggleMenu()"><span class="menu-num">02</span>Résumé</a></li>
      <li><a onclick="goTo('skills');toggleMenu()"><span class="menu-num">03</span>Skills</a></li>
      <li><a onclick="goTo('project');toggleMenu()"><span class="menu-num">04</span>Project</a></li>
      <li><a onclick="goTo('interests');toggleMenu()"><span class="menu-num">05</span>Interests</a></li>
      <li><a onclick="goTo('contact');toggleMenu()"><span class="menu-num">06</span>Contact</a></li>
    </ul>
  </div>

  <!-- ── HOME PAGE ──────────────────────────── -->
  <div class="page active" id="page-home">
    <div class="page-inner">
      <div class="hero-bg-letter">S</div>
      <div class="hero-tag">UI/UX Designer · Artist · Founder — 2025</div>
      <h1 class="hero-name">
        Sainith<br>
        <span class="it">Ramesh</span>
      </h1>
      <div class="hero-divider"></div>
      <div class="hero-bottom">
        <div class="hero-roles">
          <span class="hero-role">UI / UX Design</span>
          <span class="hero-role">Art</span>
          <span class="hero-role">Logo Design</span>
          <span class="hero-role">Brand Identity</span>
        </div>
        <button class="hero-cta" onclick="goTo('about')">
          View Portfolio <span class="arr">→</span>
        </button>
      </div>
    </div>
    <div class="bottom-nav">
      <span></span>
      <span class="page-counter">00 / 06</span>
      <button class="btn-nav" onclick="goTo('about')">
        About <span class="arrow">→</span>
      </button>
    </div>
  </div>

  <!-- ── ABOUT PAGE ─────────────────────────── -->
  <div class="page from-right" id="page-about">
    <div class="page-inner">
      <div class="sec-head">
        <span class="sec-num stagger">01</span>
        <h2 class="sec-title stagger">About <em>Me</em></h2>
        <div class="sec-line stagger"></div>
      </div>
      <div class="about-grid">
        <div>
          <p class="about-p stagger">
            I'm Sainith Ramesh — a <strong>UI/UX designer, portrait artist, and logo designer</strong>
            based in Kannur, Kerala. Born and raised in <strong>Saudi Arabia</strong> —
            a multicultural environment that shaped a global mindset.
          </p>
          <p class="about-p stagger">
            I work at the intersection of <strong>design, art, and brand identity</strong>.
            Currently completing a UI/UX Design course at <strong>GTech Kannur</strong>
            while building SAIGE — a luxury streetwear brand.
          </p>
          <p class="about-p stagger">
            My approach is detail-oriented and intentional.
            Whether it's a digital interface, a portrait,etc or a brand mark —
            every piece of work is <strong>built to stand apart</strong>.
          </p>
        </div>
        <div class="info-table stagger">
          <div class="info-row"><span class="info-k">Full Name</span><span class="info-v">Sainith Ramesh</span></div>
          <div class="info-row"><span class="info-k">Role</span><span class="info-v">UI/UX Designer</span></div>
          <div class="info-row"><span class="info-k">Location</span><span class="info-v">Kannur, Kerala, India</span></div>
          <div class="info-row"><span class="info-k">Origin</span><span class="info-v">Dammam, Saudi Arabia</span></div>
          <div class="info-row"><span class="info-k">Currently</span><span class="info-v">GTech Kannur — UI/UX</span></div>
          <div class="info-row"><span class="info-k">Brand</span><span class="info-v">Founder — SAIGE</span></div>
          <div class="info-row"><span class="info-k">Available</span><span class="info-v">Freelance & Collabs</span></div>
        </div>
      </div>
    </div>
    <div class="bottom-nav">
      <button class="btn-nav" onclick="goTo('home')"><span class="arrow">←</span> Home</button>
      <span class="page-counter">01 / 06</span>
      <button class="btn-nav" onclick="goTo('resume')">Résumé <span class="arrow">→</span></button>
    </div>
  </div>

  <!-- ── RESUME PAGE ────────────────────────── -->
  <div class="page from-right" id="page-resume">
    <div class="page-inner">
      <div class="sec-head">
        <span class="sec-num stagger">02</span>
        <h2 class="sec-title stagger"><em>Résumé</em></h2>
        <div class="sec-line stagger"></div>
      </div>
      <div class="res-grid">
        <div class="res-col stagger">
          <div class="res-col-title">Education</div>
          <div class="res-item">
            <div class="r-period">20 May 2025 — Present</div>
            <div class="r-title">GTech Kannur</div>
            <div class="r-sub">UI/UX Design Course</div>
            <div class="r-desc">Currently enrolled. Covering user research, wireframing, prototyping, and design systems.</div>
          </div>
          <div class="res-item">
            <div class="r-period">Higher Secondary</div>
            <div class="r-title">SN Trust Thottada</div>
            <div class="r-sub">Higher Secondary Education</div>
            <div class="r-desc">Completed higher secondary studies in Kannur, Kerala, India.</div>
          </div>
          <div class="res-item">
            <div class="r-period">Early Years — Till Grade 8</div>
            <div class="r-title">International Indian School Dammam</div>
            <div class="r-sub">Primary & Middle School · Saudi Arabia</div>
            <div class="r-desc">Studied in Dammam, Saudi Arabia. A multicultural environment that shaped a global perspective.</div>
          </div>
        </div>
        <div class="res-col stagger">
          <div class="res-col-title">Skills & Expertise</div>
          <div class="res-item">
            <div class="r-period">Design</div>
            <div class="r-title">UI / UX Design</div>
            <div class="r-sub">Figma · Wireframing · Prototyping</div>
            <div class="r-desc">End-to-end digital product design — from concept to high-fidelity prototype.</div>
          </div>
          <div class="res-item">
            <div class="r-period">Art & Identity</div>
            <div class="r-title">Art & Logo Design</div>
            <div class="r-sub">Portrait · Logo · Brand Identity</div>
            <div class="r-desc">Portrait work, logo systems, and visual brand identities,etc — all rooted in art.</div>
          </div>
          <div class="res-item">
            <div class="r-period">Software</div>
            <div class="r-title">Adobe Suite</div>
            <div class="r-sub">Photoshop · Illustrator · Figma</div>
            <div class="r-desc">Professional-grade tools for design, art, and brand work.</div>
          </div>
        </div>
      </div>
    </div>
    <div class="bottom-nav">
      <button class="btn-nav" onclick="goTo('about')"><span class="arrow">←</span> About</button>
      <span class="page-counter">02 / 06</span>

      <span class="page-counter">06 / 06</span>
      <button class="btn-nav" onclick="goTo('home')">Home <span class="arrow">→</span></button>
    </div>
  </div>

  <script>
    const pages = ['home','about','resume','skills','project','interests','contact'];
    const labels = ['Home','About','Résumé','Skills','Project','Interests','Contact'];
    let current = 0;
    let transitioning = false;

    function goTo(id) {
      if(transitioning) return;
      const next = pages.indexOf(id);
      if(next === current) return;
      transitioning = true;

      const currentPage = document.getElementById('page-' + pages[current]);
      const nextPage    = document.getElementById('page-' + id);
      const dir = next > current ? 1 : -1;

      // set next page starting position
      nextPage.classList.remove('from-right','from-left','exit-left','exit-right','active');
      nextPage.style.transform = dir > 0 ? 'translateX(60px)' : 'translateX(-60px)';
      nextPage.style.opacity = '0';
      nextPage.style.pointerEvents = 'none';

      // force reflow
      nextPage.offsetHeight;

      // animate out current
      currentPage.style.transition = 'opacity .5s cubic-bezier(.16,1,.3,1), transform .5s cubic-bezier(.16,1,.3,1)';
      currentPage.style.opacity = '0';
      currentPage.style.transform = dir > 0 ? 'translateX(-60px)' : 'translateX(60px)';

      // animate in next
      nextPage.style.transition = 'opacity .5s cubic-bezier(.16,1,.3,1), transform .5s cubic-bezier(.16,1,.3,1)';
      nextPage.style.opacity = '1';
      nextPage.style.transform = 'translateX(0)';
      nextPage.style.pointerEvents = 'all';

      setTimeout(() => {
        currentPage.classList.remove('active');
        currentPage.style.opacity = '';
        currentPage.style.transform = '';
        currentPage.style.transition = '';
        currentPage.style.pointerEvents = '';

        nextPage.classList.add('active');
        nextPage.style.opacity = '';
        nextPage.style.transform = '';
        nextPage.style.transition = '';

        current = next;
        document.getElementById('nav-indicator').textContent = labels[current];

        // scroll to top
        nextPage.scrollTop = 0;

        // trigger stagger animations
        triggerStagger(nextPage);

        transitioning = false;
      }, 520);
    }

    function triggerStagger(page) {
      const items = page.querySelectorAll('.stagger');
      items.forEach(el => {
        el.classList.remove('show');
        el.style.animationDelay = '';
      });
      // force reflow
      page.offsetHeight;
      items.forEach((el, i) => {
        el.style.animationDelay = (i * 0.07) + 's';
        el.classList.add('show');
      });
    }

    function toggleMenu() {
      document.getElementById('menu-overlay').classList.toggle('open');
    }

    // keyboard navigation
    document.addEventListener('keydown', e => {
      if(e.key === 'ArrowRight' && current < pages.length - 1) goTo(pages[current + 1]);
      if(e.key === 'ArrowLeft'  && current > 0) goTo(pages[current - 1]);
      if(e.key === 'Escape') document.getElementById('menu-overlay').classList.remove('open');
    });

    // touch/swipe
    let touchX = 0;
    document.addEventListener('touchstart', e => { touchX = e.touches[0].clientX; });
    document.addEventListener('touchend', e => {
      const diff = touchX - e.changedTouches[0].clientX;
      if(Math.abs(diff) > 60) {
        if(diff > 0 && current < pages.length - 1) goTo(pages[current + 1]);
        if(diff < 0 && current > 0) goTo(pages[current - 1]);
      }
    });

    // init home stagger
    triggerStagger(document.getElementById('page-home'));
  </script>
</body>
</html>